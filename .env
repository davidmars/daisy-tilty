# Variables communes  tous les modes Vite.
# Les valeurs spcifiques dev/prod sont dfinies dans:
# - .env.development
# - .env.production

# Valeurs de secours (neutres)
VITE_ENV=default
VITE_WEB3FORMS_ACCESS_KEY=

# Renseigner la vraie cl dans `.env.local` ou `.env.production.local`.

# ── Animations au scroll (désactivées par défaut) ────────────────────────
# Activer dans .env.local pour le développement local.
VITE_SMOOTH_SCROLL=true
VITE_PARALLAX=true
VITE_AOS=true
